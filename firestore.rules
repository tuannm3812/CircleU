rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /profile/{profileID} {
        allow read, create, update, delete: if isOwner(uid) && profileID == "main";
      }

      match /journalEntries/{entryID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /aiReflectionSessions/{sessionID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /quests/{questID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /tipsPracticeSessions/{sessionID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /rewardState/{rewardStateID} {
        allow read, create, update, delete: if isOwner(uid) && rewardStateID == "main";
      }

      match /pointEntries/{pointEntryID} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /activityEvents/{activityEventID} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    // Public circles — every signed-in user can read the global list. Writes are restricted:
    // - create: caller must stamp themselves as the creator
    // - update: only the creator can edit metadata (name/intention/emoji/coverImagesBase64),
    //           BUT any signed-in user can mutate their own membership/like/favorite status.
    // - delete: only the creator
    match /circles/{circleID} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.creatorUserID == request.auth.uid;

      allow update: if isSignedIn() && (
        // Creator-only fields are unchanged when this is a membership/like/favorite toggle.
        (resource.data.creatorUserID == request.auth.uid)
        || (
          request.resource.data.creatorUserID == resource.data.creatorUserID
          && request.resource.data.name == resource.data.name
          && request.resource.data.intention == resource.data.intention
          && request.resource.data.emoji == resource.data.emoji
          && request.resource.data.creatorName == resource.data.creatorName
        )
      );

      allow delete: if isSignedIn() && resource.data.creatorUserID == request.auth.uid;

      // Helper function: checks if requesting user is in the circle's member list
      function isCircleMember() {
        return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/circles/{circleID}).data.memberUserIDs;
      }

      // Posts subcollection — same public read, member-gated writes.
      match /posts/{postID} {
        allow read: if isSignedIn();

        // Gated: only members can create posts in this circle
        allow create: if isCircleMember()
          && request.resource.data.authorUserID == request.auth.uid;

        // Anyone signed-in can mutate `likedBy` (for like toggle) and `replies`
        // (for adding new replies). The author can edit text or delete.
        allow update: if isSignedIn() && (
          resource.data.authorUserID == request.auth.uid
          || (
            request.resource.data.authorUserID == resource.data.authorUserID
            && request.resource.data.text == resource.data.text
            && request.resource.data.who == resource.data.who
            && request.resource.data.createdAt == resource.data.createdAt
          )
        );

        allow delete: if isSignedIn() && resource.data.authorUserID == request.auth.uid;
      }
    }

    match /{document=**} {
      allow read, create, update, delete: if false;
    }
  }
}
